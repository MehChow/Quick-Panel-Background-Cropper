{
  "expo": {
    "name": "Quick Panel Background Cropper",
    "slug": "quick-panel-background-cropper",
    "version": "1.0.0",
    "orientation": "portrait",
    "icon": "./assets/images/appicon.png",
    "scheme": "quickpanelbackgroundcropper",
    "userInterfaceStyle": "automatic",
    "android": {
      "predictiveBackGestureEnabled": false,
      "package": "com.meh_chow.quickpanelbackgroundcropper"
    },
    "plugins": [
      "expo-router",
      [
        "expo-image-picker",
        {
          "photosPermission": "Choose an image to preview and export quick panel crops.",
          "cameraPermission": false,
          "microphonePermission": false
        }
      ],
      [
        "expo-media-library",
        {
          "photosPermission": "Allow access to save quick panel export images.",
          "savePhotosPermission": "Save quick panel export images to your photo library.",
          "granularPermissions": [],
          "isAccessMediaLocationEnabled": false
        }
      ],
      "@react-native-vector-icons/lucide",
      [
        "expo-splash-screen",
        {
          "backgroundColor": "#09090b",
          "android": {
            "image": "./assets/images/appicon.png",
            "imageWidth": 76
          }
        }
      ],
      "expo-localization",
      "expo-image"
    ],
    "experiments": {
      "typedRoutes": true,
      "reactCompiler": true
    },
    "owner": "meh_chow",
    "extra": {
      "router": {},
      "eas": {
        "projectId": "a6ede84a-b016-4465-9663-198d32a222cc"
      }
    }
  }
}
